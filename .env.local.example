# Copy this file to .env.local and fill in values.
# .env.local is gitignored. NEVER commit secrets.

# --- Supabase ---
# From your Supabase project dashboard:
#   Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

#   Settings > API Keys > Publishable key (sb_publishable_...)
#   Safe to expose in the browser. This is the new name for the old "anon" key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

#   Settings > API Keys > Secret key (sb_secret_...)
#   SERVER-ONLY. Never expose. This is the new name for the old "service_role" key.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# From https://supabase.com/dashboard/account/tokens
# (Personal Access Token for the Supabase CLI, used by `supabase link` etc.)
SUPABASE_ACCESS_TOKEN=sbp_...

# Direct Postgres connection used by Drizzle (integration tests, scripts,
# backups). TODO Jonathan: get the DB password from
#   Supabase dashboard > Settings > Database > Database password
# and replace [PASSWORD] below. The project ref is already filled in.
DATABASE_URL=postgres://postgres:[PASSWORD]@db.ygirnurpjqsthggfboer.supabase.co:5432/postgres

# --- Google Cloud (Maps) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- App URL (Vercel sets VERCEL_URL in production) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stripe (Connect platform = Smart Fusion Marketing Inc) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Subscription price IDs — one per (plan × billing cycle). Created via
# `node scripts/seed-stripe-products.mjs` against test or live Stripe;
# consumed by src/lib/billing/plans.ts. Idempotent — safe to re-run.
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_GROWTH_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_SCALE_MONTHLY=price_...
STRIPE_PRICE_SCALE_YEARLY=price_...

# Founding-member promotion: $200 CAD off Growth, lifetime. Customer types
# "FOUNDER" at checkout (or we apply it server-side for marked founder
# accounts). Created by the same seed script. Coupon is a stable id;
# promo code id is generated.
STRIPE_FOUNDER_COUPON_ID=FOUNDER_GROWTH_LIFETIME
STRIPE_FOUNDER_PROMO_CODE_ID=promo_...

# --- QuickBooks Online (Intuit Developer app) ---
# Used for QBO Import V1 (and later QBO export). Create the app at
# developer.intuit.com → My Apps → Keys & credentials. The "Development"
# tab keys talk to the Intuit sandbox; "Production" keys talk to real
# customer QBO companies (gated behind app review). Redirect URI must be
# whitelisted under Settings → Redirect URIs in BOTH tabs.
QBO_CLIENT_ID=ABxxxx...
QBO_CLIENT_SECRET=...
QBO_ENVIRONMENT=sandbox
QBO_REDIRECT_URI=http://localhost:3000/api/qbo/callback
# Server secret used to HMAC-sign the OAuth state cookie. Any high-
# entropy string (32+ bytes). Falls back to SUPABASE_SERVICE_ROLE_KEY
# if unset (same secrecy guarantees).
QBO_STATE_SECRET=

# --- Resend ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@smartfusion.ca

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Sentry (error monitoring, optional) ---
# Create a Sentry project at https://sentry.io and paste the DSN here.
# Leave empty to use console-only error reporting.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# --- Platform Admin ---
# Only this email can access /admin
ADMIN_EMAIL=

# --- AI Chat ---
CHAT_MODEL=claude-sonnet-4-6
VOICE_MODEL=claude-sonnet-4-6

# --- ElevenLabs (TTS voice, optional — falls back to browser) ---
# Go to ElevenLabs > Voices > pick one > copy Voice ID.
# Leave empty to use browser SpeechSynthesis as fallback.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Backups (GitHub Actions secrets, not runtime env) ---
# Set as repo secrets for .github/workflows/nightly-backup.yml +
# restore-drill.yml. Listed here so future-you knows they exist.
#
# BACKUP_DATABASE_URL       # direct Postgres URL to Supabase prod
# BACKUP_ENCRYPTION_KEY     # 32+ byte random passphrase for openssl aes-256-cbc
# R2_ACCOUNT_ID             # Cloudflare R2 account id
# R2_BUCKET                 # R2 bucket name, e.g. heyhenry-backups
# R2_ACCESS_KEY_ID          # R2 API token (S3-compatible)
# R2_SECRET_ACCESS_KEY
# RESEND_API_KEY            # for ops failure alerts
# OPS_ALERTS_TO_EMAIL       # optional, defaults to riffninjavideos@gmail.com
# OPS_ALERTS_FROM_EMAIL     # optional, defaults to ops@mail.heyhenry.io

# In-app feedback button → ops kanban intake
OPS_BASE_URL=https://ops.heyhenry.io
OPS_FEEDBACK_KEY=ops_...     # full token, scope=write:feedback
