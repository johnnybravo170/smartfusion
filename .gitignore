# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/.vitest

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase
supabase/.branches
supabase/.temp

# drizzle-kit scratch output. Supabase migrations are the source of truth;
# anything drizzle-kit generates here is copied into supabase/migrations/ by hand.
/drizzle/migrations

# Sentry Config File
.env.sentry-build-plugin

# Local-only output from setup scripts (contains secrets — never commit)
*.local
!.env.local.example
.claude/scheduled_tasks.lock
