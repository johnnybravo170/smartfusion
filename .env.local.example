# Copy this file to .env.local and fill in values.
# .env.local is gitignored. NEVER commit secrets.

# --- Supabase ---
# From your Supabase project dashboard:
#   Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

#   Settings > API Keys > Publishable key (sb_publishable_...)
#   Safe to expose in the browser. This is the new name for the old "anon" key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

#   Settings > API Keys > Secret key (sb_secret_...)
#   SERVER-ONLY. Never expose. This is the new name for the old "service_role" key.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# From https://supabase.com/dashboard/account/tokens
# (Personal Access Token for the Supabase CLI, used by `supabase link` etc.)
SUPABASE_ACCESS_TOKEN=sbp_...

# Direct Postgres connection used by Drizzle (integration tests, scripts,
# backups). TODO Jonathan: get the DB password from
#   Supabase dashboard > Settings > Database > Database password
# and replace [PASSWORD] below. The project ref is already filled in.
DATABASE_URL=postgres://postgres:[PASSWORD]@db.ygirnurpjqsthggfboer.supabase.co:5432/postgres

# --- Google Cloud (Maps) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Stripe (Connect platform = Smart Fusion Marketing Inc) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@smartfusion.ca

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
