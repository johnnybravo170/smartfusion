    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.4",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "sharp": "^0.34.5",
    "supabase": "^2.91.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
